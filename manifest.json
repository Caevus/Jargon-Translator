{
  "manifest_version": 2,
  "name": "Jargon Translator",
  "version": "1.2.2",
  "description": "Translate professional jargon and acronyms into plain language using AI.",
  "homepage_url": "https://github.com/Caevus/Jargon-Translator",
  "browser_specific_settings": {
    "gecko": {
      "id": "jargon-translator@caevus",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["websiteContent"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "*://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Jargon Translator",
    "default_popup": "popup.html"
  },
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+Alt+J",
        "mac": "MacCtrl+Command+J"
      },
      "description": "Translate selected text with Jargon Translator"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
