{
  "manifest_version": 2,
  "name": "Jargon Translator",
  "version": "1.1.1",
  "description": "Translate professional jargon and acronyms into plain language using AI.",
  "homepage_url": "https://github.com/Caevus/Jargon-Translator",
  "browser_specific_settings": {
    "gecko": {
      "id": "jargon-translator@caevus"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "*://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Jargon Translator",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
