{
  "manifest_version": 2,
  "name": "Jargon Translator",
  "version": "1.0.0",
  "description": "Translate professional jargon and acronyms into plain language using AI.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "*://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
